{
    "name": "leadora/agents-api",
    "description": "PHP client for the Leadora agent panel API",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Leadora\\Agents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Leadora\\Agents\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
